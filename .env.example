APP_NAME=Nova Echoes
APP_ENV=development
API_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://postgres:postgres@localhost:5433/nova_echoes?sslmode=disable

# Local Postgres
POSTGRES_DB=nova_echoes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Backend auth
AUTH_MODE=off
INTERNAL_API_KEY=dev-key-change-me

# AWS / Amazon Nova
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
NOVA_VOICE_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_ANALYSIS_MODEL_ID=amazon.nova-2-lite-v1:0

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=Nova Echoes
