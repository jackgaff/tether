APP_NAME=Tether
APP_ENV=development
API_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
DATABASE_URL=postgres://postgres:postgres@localhost:5433/tether?sslmode=disable
VOICE_LAB_EXPORT_DIR=apps/api/testdata/voice-lab

# Local Postgres
POSTGRES_DB=tether
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Backend auth
AUTH_MODE=off
INTERNAL_API_KEY=dev-key-change-me

# AWS / Amazon Nova
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
# AWS_PROFILE=default
NOVA_VOICE_MODEL_ID=amazon.nova-2-sonic-v1:0
NOVA_ANALYSIS_MODEL_ID=amazon.nova-2-lite-v1:0
NOVA_DEFAULT_VOICE_ID=matthew
NOVA_ALLOWED_VOICE_IDS=tiffany,matthew,amy,olivia,kiara,arjun,ambre,florian,beatrice,lorenzo,tina,lennart,lupe,carlos,carolina,leo
NOVA_INPUT_SAMPLE_RATE=16000
NOVA_OUTPUT_SAMPLE_RATE=24000
NOVA_ENDPOINTING_SENSITIVITY=LOW
ANALYSIS_WORKER_ENABLED=true
ANALYSIS_WORKER_POLL_INTERVAL=1s
SCREENING_SCHEDULER_ENABLED=true
SCREENING_SCHEDULER_POLL_INTERVAL=5s

# Admin auth (local demo only; production must override)
ADMIN_USERNAME=demo-admin
ADMIN_PASSWORD=demo-admin-password
ADMIN_SESSION_SECRET=demo-admin-session-secret-change-me

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=Tether
